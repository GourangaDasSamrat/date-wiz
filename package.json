{
  "name": "date-wiz",
  "version": "1.0.0",
  "description": "A zero-dependency, TypeScript-native date utility library with smart formatting, business logic, and i18n support.",
  "author": "GourangaDasSamrat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GourangaDasSamrat/date-wiz.git"
  },
  "homepage": "https://GourangaDasSamrat.github.io/date-wiz-docs",
  "keywords": [
    "date",
    "time",
    "format",
    "relative",
    "i18n",
    "intl",
    "typescript",
    "zero-dependency",
    "business-days",
    "date-utils"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./format": {
      "import": "./dist/esm/format.js",
      "require": "./dist/cjs/format.js",
      "types": "./dist/types/format.d.ts"
    },
    "./relative": {
      "import": "./dist/esm/relative.js",
      "require": "./dist/cjs/relative.js",
      "types": "./dist/types/relative.d.ts"
    },
    "./business": {
      "import": "./dist/esm/business.js",
      "require": "./dist/cjs/business.js",
      "types": "./dist/types/business.d.ts"
    },
    "./parse": {
      "import": "./dist/esm/parse.js",
      "require": "./dist/cjs/parse.js",
      "types": "./dist/types/parse.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && tsc -p tsconfig.types.json && node scripts/post-build.mjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm test",
    "version:patch": "npm version patch && git push --follow-tags",
    "version:minor": "npm version minor && git push --follow-tags",
    "version:major": "npm version major && git push --follow-tags"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
